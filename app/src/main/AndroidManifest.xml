<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.faceitoff">
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-feature android:name="android.hardware.camera" android:required="true"/>
    <uses-feature android:name="android.hardware.camera.front" android:required="false"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Faceitoff">

        <!-- LOGIN (FIRST SCREEN) -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- SIGNUP -->
        <activity android:name=".SignupActivity" android:exported="false" />

        <!-- WELCOME -->
        <activity android:name=".WelcomeActivity" android:exported="false" />

        <!-- CAMERA -->
        <activity android:name=".CameraActivity" android:exported="false" />

        <!-- SUGGESTIONS (FIXED NAME) -->
        <activity android:name=".SuggestionsActivity" android:exported="false" />

        <!-- FINAL SCREENS -->
        <activity android:name=".AppsActivity" android:exported="false" />
        <activity android:name=".MusicActivity" android:exported="false" />
        <activity android:name=".ActivitiesActivity" android:exported="false" />

        <!-- MENU SCREENS -->
        <activity android:name=".ProfileActivity" android:exported="false" />
        <activity android:name=".AnalyticsActivity" android:exported="false" />

    </application>

</manifest>
